col(3) = {0.851648351648352,0.905707196029777,0.932203389830508,0.94224924012158,0.954661558109834,0.958149779735683,0.963592233009709,0.969143850499783,0.97397476340694,0.974774774774775,0.978043912175649};
col(4) = {0.851648351648352,0.905707196029777,0.92984934086629,0.94224924012158,0.953065134099617,0.959152366348195,0.964487486568238,0.969042616413496,0.972905668097758,0.974660114660115,0.978097586339925};
