legend.showframe = 0;
legend.transparency = 100;
legend.x = layer.x.to - legend.dx/2 - 0.02*(layer.x.to-layer.x.from);
legend.y = layer.y.to - legend.dy/2 - 0.02*(layer.y.to-layer.y.from);
