// Nature-style Origin figure for RAW single-parameter effects in the series system.
// Data are copied exactly from the current worksheet; no missing RAW values are fabricated.

dotool 0;
doc -s;
doc -n;
win -cd Book1;

// ---------- Panel a: correlation coefficient rho ----------
newbook name:=NRho sheet:=1 option:=lsname;
page.longname$ = "Source data - correlation coefficient";
wks.nCols = 4;
wks.col1.type = 4;
col(1) = {0.1,0.3,0.5,0.7,0.9};
col(2) = {0.851648351648352,0.863723608445297,0.888888888888889,0.930599369085173,0.970588235294118};
col(3) = {0.851648351648352,0.863723608445297,0.873684210526316,0.875634517766497,0.894941634241245};
col(4) = {0.851648351648352,0.863723608445297,0.881286549707602,0.903116943425835,0.932764934767681};
col(1)[L]$ = "Correlation coefficient rho";
col(2)[L]$ = "RAW lower";
col(3)[L]$ = "RAW upper";
col(4)[L]$ = "RAW mean";
wks.labels(L);

plotxy iy:=[NRho]Sheet1!(1,2:4) plot:=202 size:=5 legend:=1 ogl:=[<new template:=line name:=GNRho>];
page.longname$ = "RAW versus correlation coefficient";
page.title = 3;
page.aa = 1;
page.revcolor = 0;
page.updatetoprinter = 0;
page.kar = 0;
page.width = 8.9/2.54*page.resx;
page.height = 6.6/2.54*page.resy;
layer.unit = 3;
layer.left = 1.55;
layer.top = 0.55;
layer.width = 6.85;
layer.height = 4.90;
laycolor layer:=1 color:=color(255,255,255);
layer.x.showaxes = 1;
layer.y.showaxes = 1;
layer.x.grid.major = 0;
layer.x.grid.minor = 0;
layer.y.grid.major = 0;
layer.y.grid.minor = 0;
layer -gu;
range rhol = !1;
range rhou = !2;
range rhom = !3;
set rhol -l 1; set rhol -d 1; set rhol -w 550; set rhol -k 1; set rhol -kf 0; set rhol -z 6.5;
set rhol -c color(118,118,118); set rhol -cl color(118,118,118); set rhol -csf color(118,118,118);
set rhou -l 1; set rhou -d 1; set rhou -w 550; set rhou -k 2; set rhou -kf 0; set rhou -z 5.5;
set rhou -c color(182,67,66); set rhou -cl color(182,67,66); set rhou -csf color(182,67,66);
set rhom -l 1; set rhom -d 0; set rhom -w 750; set rhom -k 3; set rhom -kf 1; set rhom -z 4.5;
set rhom -c color(15,77,146); set rhom -cl color(15,77,146); set rhom -csf color(15,77,146);
layer.x.from = 0.1;
layer.x.to = 0.9;
layer.x.inc = 0.2;
layer.y.from = 0.84;
layer.y.to = 0.98;
layer.y.inc = 0.02;
layer.tickstyle = 1;
layer.tickW = 1;
layer.x.label.font = font(Arial);
layer.y.label.font = font(Arial);
layer.x.label.fsize = 7;
layer.y.label.fsize = 7;
layer.x.label.decPlaces = 1;
layer.y.label.decPlaces = 2;
xb.text$ = "\f:SimSun(相关系数) \f:Arial(\g(r))";
yl.text$ = "\f:Arial(\i(RAW)\-(\i(i)))";
xb.fsize = 8;
yl.fsize = 8;
legend.text$ = "\l(1) \f:Arial(RAW) \f:SimSun(下界)
\l(2) \f:Arial(RAW) \f:SimSun(上界)
\l(3) \f:Arial(RAW) \f:SimSun(平均值)";
legend.fsize = 7;
legend.showframe = 0;
legend.transparency = 100;
legend.x = layer.x.from + legend.dx/2 + 0.02*(layer.x.to-layer.x.from);
legend.y = layer.y.to - legend.dy/2 - 0.02*(layer.y.to-layer.y.from);
page -s;
page -r;
expGraph type:=svg filename:="a_RAW_相关系数" path:="D:\钢结构RRW方向\Origin相关文件\图像输出\Nature风格\单图" overwrite:=replace;
expGraph type:=pdf filename:="a_RAW_相关系数" path:="D:\钢结构RRW方向\Origin相关文件\图像输出\Nature风格\单图" overwrite:=replace;
expGraph type:=png filename:="a_RAW_相关系数" path:="D:\钢结构RRW方向\Origin相关文件\图像输出\Nature风格\单图" overwrite:=replace tr1.unit:=1 tr1.width:=8.9 tr2.png.dotsperinch:=600 tr2.png.bitsperpixel:="24-bit Color";
expGraph type:=tif filename:="a_RAW_相关系数" path:="D:\钢结构RRW方向\Origin相关文件\图像输出\Nature风格\单图" overwrite:=replace tr1.unit:=1 tr1.width:=8.9 tr2.tif.dotsperinch:=600;

// ---------- Panel b: total number of components n ----------
