range nm = !3;
set nl -l 1; set nl -d 1; set nl -w 550; set nl -k 1; set nl -kf 0; set nl -z 6.5;
set nl -c color(118,118,118); set nl -cl color(118,118,118); set nl -csf color(118,118,118);
set nu -l 1; set nu -d 1; set nu -w 550; set nu -k 2; set nu -kf 0; set nu -z 5.5;
set nu -c color(182,67,66); set nu -cl color(182,67,66); set nu -csf color(182,67,66);
set nm -l 1; set nm -d 0; set nm -w 750; set nm -k 3; set nm -kf 1; set nm -z 4.5;
set nm -c color(15,77,146); set nm -cl color(15,77,146); set nm -csf color(15,77,146);
layer.x.from = 8;
layer.x.to = 48;
layer.x.inc = 8;
layer.y.from = 0.84;
layer.y.to = 0.99;
layer.y.inc = 0.02;
layer.tickstyle = 1;
layer.tickW = 1;
layer.x.label.font = font(Arial);
layer.y.label.font = font(Arial);
layer.x.label.fsize = 7;
layer.y.label.fsize = 7;
layer.x.label.decPlaces = 0;
layer.y.label.decPlaces = 2;
xb.text$ = "\f:SimSun(构件总数) \f:Arial(\i(n))";
yl.text$ = "\f:Arial(\i(RAW)\-(\i(i)))";
xb.fsize = 8;
yl.fsize = 8;
legend.text$ = "\l(1) \f:Arial(RAW) \f:SimSun(下界)
\l(2) \f:Arial(RAW) \f:SimSun(上界)
\l(3) \f:Arial(RAW) \f:SimSun(平均值)";
legend.fsize = 7;
legend.showframe = 0;
