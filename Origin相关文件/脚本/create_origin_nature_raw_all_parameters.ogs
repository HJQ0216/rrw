// ---------- Panel c: reliability index beta ----------
newbook name:=NBeta sheet:=1 option:=lsname;
page.longname$ = "Source data - reliability index";
wks.nCols = 4;
wks.nRows = 7;
wks.col1.type = 4;
col(1) = {3.0,3.1,3.2,3.3,3.4,3.5,3.6};
col(2)[1] = 0.886262924667651;
col(3)[1] = 0.886262924667651;
col(4)[1] = 0.886262924667651;
col(1)[L]$ = "Reliability index beta";
col(2)[L]$ = "RAW lower";
col(3)[L]$ = "RAW upper";
col(4)[L]$ = "RAW mean";
col(1)[C]$ = "Only beta=3.0 has RAW data in the source table; beta=3.1-3.6 are retained as blank source rows.";
wks.labels(LC);

plotxy iy:=[NBeta]Sheet1!(1,2:4) plot:=202 size:=5 legend:=1 ogl:=[<new template:=line name:=GNBeta>];
page.longname$ = "RAW versus reliability index (available data only)";
page.title = 3;
page.aa = 1;
page.revcolor = 0;
page.updatetoprinter = 0;
page.kar = 0;
page.width = 8.9/2.54*page.resx;
page.height = 6.6/2.54*page.resy;
layer.unit = 3;
layer.left = 1.55;
layer.top = 0.55;
layer.width = 6.85;
layer.height = 4.90;
laycolor layer:=1 color:=color(255,255,255);
layer.x.showaxes = 1;
layer.y.showaxes = 1;
layer.x.grid.major = 0;
layer.x.grid.minor = 0;
layer.y.grid.major = 0;
layer.y.grid.minor = 0;
layer -gu;
range bl = !1;
range bu = !2;
range bm = !3;
set bl -l 0; set bl -d 1; set bl -w 550; set bl -k 1; set bl -kf 0; set bl -z 8;
set bl -c color(118,118,118); set bl -cl color(118,118,118); set bl -csf color(118,118,118);
set bu -l 0; set bu -d 1; set bu -w 550; set bu -k 2; set bu -kf 0; set bu -z 6.5;
set bu -c color(182,67,66); set bu -cl color(182,67,66); set bu -csf color(182,67,66);
set bm -l 0; set bm -d 0; set bm -w 750; set bm -k 3; set bm -kf 1; set bm -z 4.5;
set bm -c color(15,77,146); set bm -cl color(15,77,146); set bm -csf color(15,77,146);
layer.x.from = 2.9;
layer.x.to = 3.7;
layer.x.inc = 0.1;
layer.y.from = 0.880;
layer.y.to = 0.892;
layer.y.inc = 0.002;
layer.tickstyle = 1;
layer.tickW = 1;
layer.x.label.font = font(Arial);
layer.y.label.font = font(Arial);
layer.x.label.fsize = 7;
layer.y.label.fsize = 7;
layer.x.label.decPlaces = 1;
layer.y.label.decPlaces = 3;
xb.text$ = "\f:SimSun(可靠指标) \f:Arial(\g(b))";
yl.text$ = "\f:Arial(\i(RAW)\-(\i(i)))";
xb.fsize = 8;
yl.fsize = 8;
legend.text$ = "\l(1) \f:Arial(RAW) \f:SimSun(下界)
\l(2) \f:Arial(RAW) \f:SimSun(上界)
\l(3) \f:Arial(RAW) \f:SimSun(平均值)";
